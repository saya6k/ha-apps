diff --git a/src/hotwords.hpp b/src/hotwords.hpp
new file mode 100644
index 0000000..ef8e534
--- /dev/null
+++ b/src/hotwords.hpp
@@ -0,0 +1,19 @@
+#pragma once
+#include <cstdint>
+#include <vector>
+
+namespace pk {
+
+// Contextual (hotword) biasing for the RNN-T greedy decoder. Each phrase is a
+// token-id sequence (the caller tokenizes the phrase text with the model's
+// tokenizer and passes ids via the C API). During greedy decode, a fixed
+// `boost` is added to the logit of any token that would start a phrase or
+// continue an active partial match, nudging the argmax toward known vocabulary.
+// boost == 0 or no phrases -> no biasing.
+struct HotwordBias {
+    std::vector<std::vector<int32_t>> phrases;
+    float boost = 0.0f;
+    bool active() const { return boost != 0.0f && !phrases.empty(); }
+};
+
+} // namespace pk
