#!/command/with-contenv bashio
# vim: ft=bash
# shellcheck shell=bash
# ==============================================================================
# Sends Wyoming discovery information to Home Assistant.
# ==============================================================================
declare config

# Wait for NeMo ASR (cpp) to become available
bash -c \
    "until
        echo '{ \"type\": \"describe\" }'
            > /dev/tcp/localhost/10360; do sleep 0.5;
    done" > /dev/null 2>&1 || true;

config=$(\
    bashio::var.json \
        uri "tcp://$(hostname):10360" \
)

if bashio::discovery "wyoming" "${config}" > /dev/null; then
    bashio::log.info "Successfully send discovery information to Home Assistant."
else
    bashio::log.error "Discovery message to Home Assistant failed!"
fi
