#!/command/with-contenv bashio
# vim: ft=bash
# shellcheck shell=bash
# ==============================================================================
# Sends Wyoming discovery information to Home Assistant.
#
# Why we publish the IP instead of `$(hostname)` (the upstream
# OHF-Voice/default-agent pattern): HA Core's Wyoming integration calls
# getaddrinfo() on the URI host to open a TCP connection. Addon container
# hostnames contain underscores (e.g. addon_local_llm_conversation_agent)
# which are RFC-952-invalid; the Docker DNS resolver tolerates them but
# some HA-Core-side glibc states return EAI_NODATA ("[Errno -5] Name has
# no usable address"), which HA wraps as a user-facing "Error
# communicating with service". `hostname -i` returns the container IP,
# which is unambiguous and refreshed every restart (discovery re-fires
# per addon start) so HA Core never has to resolve our name.
# ==============================================================================
declare config
declare host

# Wait for the agent to be reachable on its TCP port.
bash -c \
    "until
        echo '{ \"type\": \"describe\" }'
            > /dev/tcp/localhost/10500; do sleep 0.5;
    done" > /dev/null 2>&1 || true;

host="$(hostname -i 2>/dev/null | awk '{print $1}')"
if [ -z "${host}" ]; then
    host="$(hostname)"
    bashio::log.warning \
        "Could not determine container IP via 'hostname -i'; falling back to hostname '${host}' (HA may hit DNS issues)."
fi

bashio::log.info "Wyoming discovery URI: tcp://${host}:10500"

config=$(\
    bashio::var.json \
        uri "tcp://${host}:10500" \
)

if bashio::discovery "wyoming" "${config}" > /dev/null; then
    bashio::log.info "Successfully sent discovery information to Home Assistant."
else
    bashio::log.error "Discovery message to Home Assistant failed!"
fi
