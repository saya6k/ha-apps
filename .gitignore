# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Desktop.ini

# Linux
.directory

# Editors / IDEs
.idea/
# .vscode/ is committed (shared dev config + devcontainer task), like
# alexbelgium/hassio-addons — not ignored.
*.swp
*.swo
*~

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# uv / pip
.uv_cache/
pip-log.txt

# Node (wardrowbe build artefacts shouldn't appear, but just in case)
node_modules/
npm-debug.log*
yarn-error.log*

# Agent dirs (.agents/): the canonical SoT for all AI tooling. Subdirs:
#   skills/    — per-app Copilot instruction pointers (also .github/instructions symlink)
#   workflows/ — Claude Code slash commands (.claude/commands symlink)
#   agents/    — Claude Code agent definitions (.claude/agents symlink)
#   manifests/ — repo-level instruction source of truth (AGENTS.md/CLAUDE.md/GEMINI.md symlink)
#   memory/    — project context notes (local-only, not tracked)
#   settings.local.json + decision logs — local-only, not tracked
# Subprojects carry no per-tool symlinks. Never link to .agents/ from any shipped doc.
**/.agents/*
!**/.agents/skills
!**/.agents/workflows
!**/.agents/agents
!**/.agents/manifests
!/.agents/settings.json
# .claude is a real dir (not a symlink) with individual symlinks inside.
# settings.local.json inside is gitignored (local overrides only).
.claude
!/.claude
/.claude/settings.local.json
.gemini
!/.gemini

# Build / cache
*.log
*.tmp
*.bak
build/
dist/

# Repo / publish artefacts that should not be committed
report/
super-linter-output/

# App stage gating — WHITELIST (default-deny). Every non-hidden top-level dir
# (i.e. every app) is local-only unless explicitly un-ignored below, so a new
# or experimental app can never be committed by accident. `/[!.]*/` ignores all
# top-level dirs that don't start with a dot; infra dirs (.github, .agents,
# .devcontainer, .vscode) are hidden and unaffected.
#
# To publish (promote to stable) an app: add `!/<slug>/` here and remove any
# `stage: experimental` from its config.yaml — stable carries NO `stage:` key
# (the add-on linter rejects an explicit `stage: stable`).
/[!.]*/
# Dev tooling (not an app) — tracked:
!/scripts/
# Published (stable) apps — tracked:
!/nemo-asr-cpp/
!/supertonic/
!/voiceprint/
!/wardrowbe/
!/zensical/
# voiceprint's 14 MB CAM++ model is fetched to /data at runtime (models.py),
# hosted as a pinned release asset — never commit a local dev copy. (Listed
# after the re-include above so this narrower exclusion wins.)
/voiceprint/models/
