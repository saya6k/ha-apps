.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Desktop.ini

# Linux
.directory

# Editors / IDEs
.idea/
# .vscode/ is committed (shared dev config + devcontainer task), like
# alexbelgium/hassio-addons — not ignored.
*.swp
*.swo
*~

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# uv / pip
.uv_cache/
pip-log.txt

# Node (wardrowbe build artefacts shouldn't appear, but just in case)
node_modules/
npm-debug.log*
yarn-error.log*

# AI tooling dirs — tracked in full; only local-override files are excluded.
**/.agents/settings.local.json
# .claude is a real dir (not a symlink) with individual symlinks inside.
# settings.local.json inside is gitignored (local overrides only).
.claude
!/.claude
/.claude/settings.local.json
.gemini
!/.gemini

# Build / cache
*.log
*.tmp
*.bak
build/
dist/

# Repo / publish artefacts that should not be committed
report/
super-linter-output/

# App stage gating — WHITELIST (default-deny). Every non-hidden top-level dir
# (i.e. every app) is gitignored unless explicitly un-ignored below. `/[!.]*/`
# ignores all top-level dirs that don't start with a dot; infra dirs (.github,
# .agents, .devcontainer, .vscode) are hidden and unaffected.
#
# To register a new app: add `!/<slug>/` here. Stage is controlled by
# config.yaml's `stage:` key (experimental or absent for stable), not by
# gitignore — all registered apps are tracked.
#
# To promote to stable: remove `stage: experimental` from config.yaml.
/[!.]*/
# Registered apps — tracked:
!/livekit-wakeword/
!/nemotron-asr-c/
!/nemo-asr-cpp/
!/supertonic/
!/voiceprint/
!/wardrowbe/
!/zensical/
# voiceprint's 14 MB CAM++ model is fetched to /data at runtime (models.py),
# hosted as a pinned release asset — never commit a local dev copy. (Listed
# after the re-include above so this narrower exclusion wins.)
/voiceprint/models/
