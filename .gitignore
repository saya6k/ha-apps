# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Desktop.ini

# Linux
.directory

# Editors / IDEs
.idea/
# .vscode/ is committed (shared dev config + devcontainer task), like
# alexbelgium/hassio-addons — not ignored.
*.swp
*.swo
*~

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# uv / pip
.uv_cache/
pip-log.txt

# Node (wardrowbe build artefacts shouldn't appear, but just in case)
node_modules/
npm-debug.log*
yarn-error.log*

# Agent dirs (.agents/): settings.local.json + decision logs, local-only by
# convention. `.agents/skills/` is the one tracked exception. `.claude` is a
# local symlink aliases -> .agents (.claude everywhere, plus .gemini at root,
# point at .agents so the tools share .agents/skills/). Never link to .agents/
# from any shipped doc.
**/.agents/*
!**/.agents/skills
.claude
.gemini
# Track wardrowbe's .claude symlink so its tracked .agents/skills/ resolves
# via .claude/skills/ (Claude Code's lookup path) on a fresh clone.
!wardrowbe/.claude

# Build / cache
*.log
*.tmp
*.bak
build/
dist/

# Repo / publish artefacts that should not be committed
report/
super-linter-output/

# voiceprint's 14 MB CAM++ model is fetched to /data at runtime (models.py),
# hosted as a pinned release asset — never commit a local dev copy.
/voiceprint/models/

# Stage gating — committed add-ons are "stable" (the default; the add-on
# linter rejects an explicit `stage: stable`, so stable add-ons carry NO
# `stage:` key). Experimental add-ons set `stage: experimental` and stay
# local-only via the lines below; delete a line here to publish that add-on.
/llm-conversation-agent/
/rethink/
/livekit-wakeword/
/nemotron-asr/
