#!/command/with-contenv bashio
# vim: ft=bash
# shellcheck shell=bash
# ==============================================================================
# Start the Supertonic Wyoming service (MNN backend).
# ==============================================================================

# Persist the MNN model cache across container recreations. The
# supertonic_mnn library defaults to ~/.cache/supertonic-mnn, so
# HOME=/data redirects it to the persistent volume.
export HOME=/data
mkdir -p /data/.cache

# Convert the warmup_voices YAML list (e.g. ["M1", "F1"]) into a
# comma-separated string for our --warmup-voices CLI flag.
warmup_voices=$(jq -r '.warmup_voices | join(",")' /data/options.json 2>/dev/null || echo "M1")

# Advanced knobs are optional in config.yaml's schema — only forward them
# when the user has actually set a value. Missing values fall through to
# the Python argparse defaults (threads=0 → auto, precision=auto, etc).
flags=()
bashio::config.has_value 'threads'    && flags+=('--threads'     "$(bashio::config 'threads')")
bashio::config.has_value 'precision'  && flags+=('--precision'   "$(bashio::config 'precision')")
bashio::config.has_value 'mnn_memory' && flags+=('--mnn-memory'  "$(bashio::config 'mnn_memory')")
bashio::config.false 'text_normalization' && flags+=('--no-text-normalization')
bashio::config.true 'no_streaming'        && flags+=('--no-streaming')
bashio::config.true 'debug_logging'       && flags+=('--debug')

# shellcheck disable=SC2068
exec python3 -m wyoming_supertonic \
    --uri 'tcp://0.0.0.0:10209' \
    --speed "$(bashio::config 'speed')" \
    --steps "$(bashio::config 'steps')" \
    --version "$(bashio::config 'model_version')" \
    --warmup-voices "${warmup_voices}" \
    ${flags[@]}
