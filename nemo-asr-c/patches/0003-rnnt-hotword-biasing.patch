+void nemo_set_hotwords(nemo_ctx_t *ctx, const int32_t *ids,
+                       const int *lens, int n, float boost) {
+    if (!ctx) return;
+    free(ctx->hw_ids); ctx->hw_ids = NULL;
+    free(ctx->hw_lens); ctx->hw_lens = NULL;
+    free(ctx->hw_offsets); ctx->hw_offsets = NULL;
+    ctx->hw_n = 0;
+    ctx->hw_boost = 0.0f;
+    if (!ids || !lens || n <= 0 || boost == 0.0f) return;
+
+    int total = 0;
+    for (int i = 0; i < n; i++) total += lens[i];
+
+    int32_t *new_ids = (int32_t *)malloc((size_t)total * sizeof(int32_t));
+    int *new_lens = (int *)malloc((size_t)n * sizeof(int));
+    int *new_offs = (int *)calloc((size_t)(n + 1), sizeof(int));
+    if (!new_ids || !new_lens || !new_offs) {
+        free(new_ids); free(new_lens); free(new_offs);
+        return;
+    }
+    memcpy(new_ids, ids, (size_t)total * sizeof(int32_t));
+    memcpy(new_lens, lens, (size_t)n * sizeof(int));
+    for (int i = 0; i < n; i++) new_offs[i + 1] = new_offs[i] + lens[i];
+
+    ctx->hw_ids = new_ids;
+    ctx->hw_lens = new_lens;
+    ctx->hw_offsets = new_offs;
+    ctx->hw_n = n;
+    ctx->hw_boost = boost;
+}
+
 void nemo_set_att_right(nemo_ctx_t *ctx, int att_right) {
     if (!ctx) return;
     if (att_right < 0) att_right = 0;
