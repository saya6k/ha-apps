+                            s->hw_active_cap = new_cap;
+                        }
+                        s->hw_active[nxt_len].phrase_idx = pi;
+                        s->hw_active[nxt_len].matched_len = pos + 1;
+                        nxt_len++;
+                    }
+                }
+                /* Start new matches for multi-token phrases whose first token matches. */
+                for (int p = 0; p < ctx->hw_n; p++) {
+                    if (ctx->hw_lens[p] > 1 && ctx->hw_ids[ctx->hw_offsets[p]] == tok) {
+                        /* Dedup: skip if already tracking (p, 1) from the advance loop above. */
+                        int dup = 0;
