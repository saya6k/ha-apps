+/* Hotword-aware joint argmax: computes full logits, applies boost, returns argmax. */
+static int joint_argmax_hotword(nemo_ctx_t *ctx, const float *enc_proj,
+                                 const float *pred_proj, nemo_rnnt_stream_t *s) {
+    const nemo_joint_t *j = &ctx->model.joint;
+    float hidden[NEMO_JOINT_HIDDEN];
+    for (int i = 0; i < NEMO_JOINT_HIDDEN; i++) {
+        float v = enc_proj[i] + pred_proj[i];
+        hidden[i] = v > 0.0f ? v : 0.0f;
+    }
+
+    /* Compute full logits via nemo_linear_weight (handles f32/bf16/q8p). */
+    float *logits = s->hw_logits;
+    nemo_linear_weight(logits, hidden, &j->out_w, j->out_b,
+                       1, NEMO_JOINT_HIDDEN, NEMO_VOCAB_WITH_BLANK);
+
+    /* Boost first token of every phrase. */
+    for (int p = 0; p < ctx->hw_n; p++) {
+        int tid = ctx->hw_ids[ctx->hw_offsets[p]];
+        if (tid >= 0 && tid < NEMO_VOCAB_WITH_BLANK)
+            logits[tid] += ctx->hw_boost;
+    }
+
+    /* Boost continuation tokens for active partial matches. */
+    for (int i = 0; i < s->hw_active_len; i++) {
+        int ph = s->hw_active[i].phrase_idx;
+        int pos = s->hw_active[i].matched_len;
+        int tid = ctx->hw_ids[ctx->hw_offsets[ph] + pos];
+        if (tid >= 0 && tid < NEMO_VOCAB_WITH_BLANK)
+            logits[tid] += ctx->hw_boost;
+    }
+
+    /* Argmax over boosted logits. */
+    int best = 0;
+    float best_val = logits[0];
+    for (int i = 1; i < NEMO_VOCAB_WITH_BLANK; i++) {
+        if (logits[i] > best_val) {
+            best_val = logits[i];
+            best = i;
+        }
+    }
+    return best;
+}
