+                            if (!p) continue;
+                            s->hw_active = p;
+                            s->hw_active_cap = new_cap;
+                        }
+                        s->hw_active[nxt_len].phrase_idx = p;
+                        s->hw_active[nxt_len].matched_len = 1;
+                        nxt_len++;
+                    }
+                }
+                s->hw_active_len = nxt_len;
