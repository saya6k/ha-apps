{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "include-component-in-tag": true,
  "include-v-in-tag": true,
  "separate-pull-requests": true,
  "pull-request-title-pattern": "chore${scope}: release ${version}",
  "changelog-sections": [
    {"type": "feat",     "section": "Features"},
    {"type": "fix",      "section": "Bug Fixes"},
    {"type": "perf",     "section": "Performance"},
    {"type": "revert",   "section": "Reverts"},
    {"type": "docs",     "section": "Documentation"},
    {"type": "refactor", "section": "Code Refactoring"},
    {"type": "build",    "section": "Build System"},
    {"type": "ci",       "section": "CI"},
    {"type": "chore",    "section": "Chores", "hidden": true},
    {"type": "test",     "section": "Tests",  "hidden": true},
    {"type": "style",    "section": "Style",  "hidden": true}
  ],
  "packages": {
    "livekit-wakeword": {
      "component": "livekit-wakeword",
      "package-name": "livekit-wakeword",
      "changelog-path": "CHANGELOG.md",
      "exclude-paths": ["livekit-wakeword/.agents"],
      "extra-files": [
        {"type": "yaml", "path": "config.yaml", "jsonpath": "$.version"},
        {"type": "toml", "path": "pyproject.toml", "jsonpath": "$.project.version"}
      ]
    },
    "nemo-asr-cpp": {
      "component": "nemo-asr-cpp",
      "package-name": "nemo-asr-cpp",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {"type": "yaml", "path": "config.yaml", "jsonpath": "$.version"},
        {"type": "toml", "path": "pyproject.toml", "jsonpath": "$.project.version"}
      ]
    },
    "nemotron-asr": {
      "component": "nemotron-asr",
      "package-name": "nemotron-asr",
      "changelog-path": "CHANGELOG.md",
      "exclude-paths": ["nemotron-asr/.agents"],
      "extra-files": [
        {"type": "yaml", "path": "config.yaml", "jsonpath": "$.version"},
        {"type": "toml", "path": "pyproject.toml", "jsonpath": "$.project.version"}
      ]
    },
    "supertonic": {
      "component": "supertonic",
      "package-name": "supertonic",
      "changelog-path": "CHANGELOG.md",
      "exclude-paths": ["supertonic/.agents"],
      "extra-files": [
        {"type": "yaml", "path": "config.yaml", "jsonpath": "$.version"},
        {"type": "toml", "path": "pyproject.toml", "jsonpath": "$.project.version"}
      ]
    },
    "voiceprint": {
      "component": "voiceprint",
      "package-name": "voiceprint",
      "changelog-path": "CHANGELOG.md",
      "exclude-paths": ["voiceprint/.agents"],
      "extra-files": [
        {"type": "yaml", "path": "config.yaml", "jsonpath": "$.version"},
        {"type": "toml", "path": "pyproject.toml", "jsonpath": "$.project.version"}
      ]
    },
    "wardrowbe": {
      "component": "wardrowbe",
      "package-name": "wardrowbe",
      "changelog-path": "CHANGELOG.md",
      "exclude-paths": ["wardrowbe/.agents"],
      "extra-files": [
        {"type": "yaml", "path": "config.yaml", "jsonpath": "$.version"}
      ]
    },
    "zensical": {
      "component": "zensical",
      "package-name": "zensical",
      "changelog-path": "CHANGELOG.md",
      "exclude-paths": ["zensical/.agents"],
      "extra-files": [
        {"type": "yaml", "path": "config.yaml", "jsonpath": "$.version"}
      ]
    }
  }
}
