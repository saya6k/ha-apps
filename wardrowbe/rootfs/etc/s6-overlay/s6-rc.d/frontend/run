#!/usr/bin/with-contenv bash
set -euo pipefail

# Wait for backend health endpoint
echo "[frontend] waiting for backend …"
for _ in $(seq 1 90); do
  if curl -sf http://127.0.0.1:${BACKEND_PORT}/api/v1/health >/dev/null 2>&1; then
    break
  fi
  sleep 1
done

cd /app/frontend

export PORT="${FRONTEND_PORT}"
export HOSTNAME="0.0.0.0"
export BACKEND_URL="http://127.0.0.1:${BACKEND_PORT}"
export NEXT_PUBLIC_API_URL="http://127.0.0.1:${BACKEND_PORT}"
# NEXTAUTH_URL is set by init script (internal for dev, external for OIDC)
export NEXTAUTH_URL="${NEXTAUTH_URL}"
export NEXTAUTH_SECRET="${NEXTAUTH_SECRET}"
export DEV_LOGIN="${DEV_LOGIN:-true}"

# Forward OIDC vars when configured
export OIDC_ISSUER_URL="${OIDC_ISSUER_URL:-}"
export OIDC_CLIENT_ID="${OIDC_CLIENT_ID:-}"
export OIDC_CLIENT_SECRET="${OIDC_CLIENT_SECRET:-}"

echo "[frontend] NEXTAUTH_URL=${NEXTAUTH_URL}"
echo "[frontend] DEV_LOGIN=${DEV_LOGIN}"

echo "[frontend] starting Next.js on port ${PORT} …"
exec node server.js
