#!/usr/bin/with-contenv bash
# shellcheck shell=bash
set -euo pipefail
mkdir -p /run/nginx /var/lib/nginx/logs

# Wait for uvicorn before serving — prevents upstream connection-refused errors
# during the window between nginx start and backend completing migrations.
for _ in $(seq 1 60); do
  curl -sf http://127.0.0.1:8000/api/v1/health >/dev/null 2>&1 && break
  sleep 1
done

exec nginx -g "daemon off;"
