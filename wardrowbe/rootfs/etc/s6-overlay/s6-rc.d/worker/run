#!/usr/bin/with-contenv bash
# shellcheck shell=bash
set -euo pipefail

# Wait for postgres
for _ in $(seq 1 60); do
  pg_isready -h 127.0.0.1 -p "${POSTGRES_PORT}" -q 2>/dev/null && break
  sleep 1
done

# Wait for redis
for _ in $(seq 1 30); do
  redis-cli -h 127.0.0.1 -p "${REDIS_PORT}" ping 2>/dev/null | grep -q PONG && break
  sleep 1
done

# Wait a few extra seconds for backend to finish migrations
sleep 5

cd /app/backend

echo "[worker] starting arq worker …"
exec /app/backend/run_worker.py
