#!/usr/bin/with-contenv bash
# shellcheck shell=bash
set -euo pipefail
mkdir -p /run/postgresql

# Mirror the ownership detection from 00-init.sh (see there for rationale).
_data_uid=$(stat -c '%u' /data/postgres/data 2>/dev/null || echo "0")
_data_gid=$(stat -c '%g' /data/postgres/data 2>/dev/null || echo "0")
if [ "$_data_uid" != "0" ]; then
  exec env LD_PRELOAD=/usr/local/lib/libfakeeuid.so \
    /usr/local/bin/switch-user "$_data_uid" "$_data_gid" \
    postgres -D /data/postgres/data
else
  exec env LD_PRELOAD=/usr/local/lib/libfakeeuid.so \
    postgres -D /data/postgres/data
fi
