root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{yaml,yml,json,toml}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false  # trailing spaces are line-break syntax

[*.{sh,bash}]
indent_size = 4

[*.py]
indent_size = 4

[Dockerfile]
indent_size = 4

[Makefile]
indent_style = tab
